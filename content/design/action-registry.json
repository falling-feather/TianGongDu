{
  "$schema": "../schemas/action-registry.schema.json",
  "schemaVersion": "1.0.0",
  "contexts": [
    { "id": "gameplay", "priority": 10, "capturesText": false },
    { "id": "dialogue", "priority": 20, "capturesText": false },
    { "id": "menu", "priority": 30, "capturesText": false },
    { "id": "text_entry", "priority": 40, "capturesText": true },
    { "id": "system", "priority": 0, "capturesText": false }
  ],
  "actions": [
    { "id": "move_x", "valueType": "axis1d", "contexts": ["gameplay"], "edgePolicy": "continuous", "clearOnBlur": true },
    { "id": "move_y", "valueType": "axis1d", "contexts": ["gameplay"], "edgePolicy": "continuous", "clearOnBlur": true },
    { "id": "jump", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "light_attack", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "heavy_attack", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "guard", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "hold_or_toggle", "clearOnBlur": true },
    { "id": "evade", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "weapon_skill", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "lantern", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "hold_or_toggle", "clearOnBlur": true },
    { "id": "interact", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "stance_previous", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "stance_next", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "stance_direct_1", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "stance_direct_2", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "stance_direct_3", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "switch_weapon", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_or_hold", "clearOnBlur": true },
    { "id": "quick_item", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_or_hold", "clearOnBlur": true },
    { "id": "open_map", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "open_journal", "valueType": "digital", "contexts": ["gameplay"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "ui_navigate", "valueType": "vector2", "contexts": ["dialogue", "menu"], "edgePolicy": "repeat_with_ui_delay", "clearOnBlur": true },
    { "id": "ui_confirm", "valueType": "digital", "contexts": ["dialogue", "menu"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "ui_cancel", "valueType": "digital", "contexts": ["dialogue", "menu", "text_entry"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "ui_tab_previous", "valueType": "digital", "contexts": ["menu"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "ui_tab_next", "valueType": "digital", "contexts": ["menu"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "pause", "valueType": "digital", "contexts": ["system"], "edgePolicy": "press_release", "clearOnBlur": true },
    { "id": "text_input", "valueType": "text", "contexts": ["text_entry"], "edgePolicy": "text_commit", "clearOnBlur": true }
  ],
  "defaultBindings": [
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyA", "actionId": "move_x", "gesture": "held_axis", "scale": -1 },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyD", "actionId": "move_x", "gesture": "held_axis", "scale": 1 },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyW", "actionId": "move_y", "gesture": "held_axis", "scale": 1 },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyS", "actionId": "move_y", "gesture": "held_axis", "scale": -1 },
    { "profile": "keyboard_mouse", "control": "Keyboard.Space", "actionId": "jump", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Mouse.Primary", "actionId": "light_attack", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Mouse.Secondary", "actionId": "heavy_attack", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.ShiftLeft", "actionId": "guard", "gesture": "hold" },
    { "profile": "keyboard_mouse", "control": "Keyboard.ControlLeft", "actionId": "evade", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyC", "actionId": "evade", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyQ", "actionId": "weapon_skill", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyE", "actionId": "lantern", "gesture": "hold" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyF", "actionId": "interact", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Mouse.WheelUp", "actionId": "stance_previous", "gesture": "step" },
    { "profile": "keyboard_mouse", "control": "Mouse.WheelDown", "actionId": "stance_next", "gesture": "step" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Digit1", "actionId": "stance_direct_1", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Digit2", "actionId": "stance_direct_2", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Digit3", "actionId": "stance_direct_3", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyV", "actionId": "switch_weapon", "gesture": "press_or_hold" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyR", "actionId": "quick_item", "gesture": "press_or_hold" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyM", "actionId": "open_map", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.KeyJ", "actionId": "open_journal", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.ArrowKeys", "actionId": "ui_navigate", "gesture": "axis2d" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Enter", "actionId": "ui_confirm", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Escape", "actionId": "ui_cancel", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.BracketLeft", "actionId": "ui_tab_previous", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.BracketRight", "actionId": "ui_tab_next", "gesture": "press" },
    { "profile": "keyboard_mouse", "control": "Keyboard.Escape", "actionId": "pause", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.LeftStickX", "actionId": "move_x", "gesture": "axis1d", "scale": 1 },
    { "profile": "gamepad_standard", "control": "Gamepad.LeftStickY", "actionId": "move_y", "gesture": "axis1d", "scale": -1 },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonSouth", "actionId": "jump", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonWest", "actionId": "light_attack", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonNorth", "actionId": "heavy_attack", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.BumperLeft", "actionId": "guard", "gesture": "hold" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonEast", "actionId": "evade", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.BumperRight", "actionId": "weapon_skill", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.TriggerLeft", "actionId": "lantern", "gesture": "hold" },
    { "profile": "gamepad_standard", "control": "Gamepad.TriggerRight", "actionId": "interact", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.DpadLeft", "actionId": "stance_previous", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.DpadRight", "actionId": "stance_next", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.DpadUp", "actionId": "switch_weapon", "gesture": "press_or_hold" },
    { "profile": "gamepad_standard", "control": "Gamepad.DpadDown", "actionId": "quick_item", "gesture": "press_or_hold" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonBack", "actionId": "open_map", "gesture": "tap_deferred" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonBack", "actionId": "open_journal", "gesture": "hold" },
    { "profile": "gamepad_standard", "control": "Gamepad.LeftStick", "actionId": "ui_navigate", "gesture": "axis2d" },
    { "profile": "gamepad_standard", "control": "Gamepad.Dpad", "actionId": "ui_navigate", "gesture": "axis2d" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonSouth", "actionId": "ui_confirm", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonEast", "actionId": "ui_cancel", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.BumperLeft", "actionId": "ui_tab_previous", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.BumperRight", "actionId": "ui_tab_next", "gesture": "press" },
    { "profile": "gamepad_standard", "control": "Gamepad.ButtonStart", "actionId": "pause", "gesture": "press" },
    { "profile": "text_input", "control": "DOM.BeforeInputOrInputCommit", "actionId": "text_input", "gesture": "text_commit" },
    { "profile": "text_input", "control": "DOM.CompositionCommit", "actionId": "text_input", "gesture": "text_commit" }
  ],
  "rules": {
    "physicalRepeatCreatesPressEdges": false,
    "latestDeviceChangesGlyphOnly": true,
    "contextChangeClearsHeldGameplayActions": true,
    "gamepadDeadzoneDefinedPerDeviceProfile": true,
    "textCompositionNeverEntersGameplay": true,
    "higherContextPriorityWins": true,
    "unhandledInputFallsThrough": true,
    "browserTabReservedForDomFocus": true,
    "escapeBrowserExitPrecedesActionDispatch": true,
    "sharedTapHoldEmitsExactlyOneAction": true,
    "ordinaryAndImeTextUseCommitPaths": true,
    "holdThresholdMs": 350,
    "uiRepeatDelayMs": 350,
    "uiRepeatIntervalMs": 90,
    "gamepadStickDeadzone": 0.18,
    "gamepadTriggerDeadzone": 0.05
  }
}
