{
  "$schema": "../schemas/web-abi.schema.json",
  "schemaVersion": "1.0.0",
  "abi": {
    "major": 1,
    "minor": 2,
    "endianness": "little",
    "maxMessageBytes": 262144,
    "headerBytes": 40
  },
  "payloads": {
    "bootConfigV1Bytes": 52,
    "uiCommandV1Bytes": 20,
    "uiEventV1Bytes": 40,
    "questUiSelectionIntentV1Bytes": 40,
    "questUiEventV1Bytes": 1288,
    "questUiCloseAckV1Bytes": 24,
    "questUiChoiceOptionCapacity": 8,
    "questUiSelectedOptionCapacity": 16,
    "questUiActorCapacity": 16,
    "questUiRetainedObjectiveCapacity": 64,
    "storageRequestV1HeaderBytes": 208,
    "storageCompletionV1HeaderBytes": 152,
    "maxStorageTransferBytes": 16777392,
    "persistentOperationV1Bytes": 80,
    "maxAtomicOperationsPerWrite": 16
  },
  "messageTypes": [
    { "id": 1, "name": "boot_config", "direction": "js_to_cpp", "payloadVersion": 1, "critical": true },
    { "id": 2, "name": "boot_result", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 3, "name": "platform_event_batch", "direction": "js_to_cpp", "payloadVersion": 1, "critical": true },
    { "id": 4, "name": "ui_command", "direction": "js_to_cpp", "payloadVersion": 1, "critical": true },
    { "id": 5, "name": "ui_event", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 6, "name": "quest_ui_selection_intent", "direction": "js_to_cpp", "payloadVersion": 1, "critical": true },
    { "id": 7, "name": "quest_ui_event", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 8, "name": "quest_ui_close_ack", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 100, "name": "storage_request", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 101, "name": "storage_completion", "direction": "js_to_cpp", "payloadVersion": 1, "critical": true },
    { "id": 102, "name": "storage_cancel", "direction": "cpp_to_js", "payloadVersion": 1, "critical": true },
    { "id": 200, "name": "diagnostic", "direction": "cpp_to_js", "payloadVersion": 1, "critical": false }
  ],
  "uiCommands": [
    { "id": 1, "name": "save_guest_checkpoint" },
    { "id": 2, "name": "retry_pending_save" }
  ],
  "questUiCloseReasons": [
    { "id": 1, "name": "selection_committed" }
  ],
  "storageOperations": [
    { "id": 1, "name": "read" },
    { "id": 2, "name": "write_atomic" },
    { "id": 3, "name": "list" },
    { "id": 4, "name": "delete" },
    { "id": 5, "name": "estimate_quota" },
    { "id": 6, "name": "request_persistence" },
    { "id": 7, "name": "export_profile" },
    { "id": 8, "name": "import_profile" },
    { "id": 9, "name": "migrate_profile" }
  ],
  "errorCodes": [
    { "id": 0, "name": "none" },
    { "id": 1, "name": "incompatible_abi" },
    { "id": 2, "name": "invalid_message" },
    { "id": 3, "name": "buffer_too_small" },
    { "id": 4, "name": "unknown_message_type" },
    { "id": 5, "name": "payload_too_large" },
    { "id": 6, "name": "backpressure" },
    { "id": 7, "name": "duplicate_completion" },
    { "id": 8, "name": "cancelled" },
    { "id": 9, "name": "stale_generation" },
    { "id": 10, "name": "timeout" },
    { "id": 11, "name": "storage_not_found" },
    { "id": 12, "name": "storage_conflict" },
    { "id": 13, "name": "storage_quota" },
    { "id": 14, "name": "storage_corrupt" },
    { "id": 15, "name": "storage_unavailable" },
    { "id": 16, "name": "internal" }
  ]
}
