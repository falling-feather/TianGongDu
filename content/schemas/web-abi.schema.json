{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangongdu.invalid/schemas/web-abi.schema.json",
  "title": "TianGongDu Web ABI Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "abi",
    "messageTypes",
    "storageOperations",
    "errorCodes"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "1.0.0" },
    "abi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major", "minor", "endianness", "maxMessageBytes", "headerBytes"],
      "properties": {
        "major": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "minor": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "endianness": { "const": "little" },
        "maxMessageBytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 },
        "headerBytes": { "const": 40 }
      }
    },
    "messageTypes": { "$ref": "#/$defs/idList" },
    "storageOperations": { "$ref": "#/$defs/idList" },
    "errorCodes": { "$ref": "#/$defs/idList" }
  },
  "$defs": {
    "idList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer", "minimum": 0, "maximum": 65535 },
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "direction": { "enum": ["js_to_cpp", "cpp_to_js"] },
          "payloadVersion": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "critical": { "type": "boolean" }
        }
      }
    }
  }
}
