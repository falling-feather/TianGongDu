      "outputTargets": ["content/npcs/rain_alley_m1_npcs.json", "content/localization/zh-CN.json"],
      "requiredFields": ["id", "displayNameKey", "roles", "emotionalRole", "routine", "fourEyeLean", "homePointId"],
      "draftFields": ["id", "displayNameKey", "tags", "designerNote", "status", "owner", "sourceNote", "roles", "emotionalRole", "homeLargeAreaId", "homePointId", "routine", "fourEyeLean", "serviceIds", "questIds", "assetRefIds"],
      "draftSeed": {
        "id": "npc.jiangnan.draft_character",
        "displayNameKey": "npc.jiangnan.draft_character.name",
        "tags": ["npc", "jiangnan", "draft"],
        "designerNote": "标准人物编辑器生成的江南 NPC 草稿。",
        "status": "draft",
        "owner": "planning",
        "sourceNote": "prototype editor draft",
        "roles": ["service", "local_memory"],
        "emotionalRole": "生活关系与地区记忆提供者",
        "homeLargeAreaId": "large_area.jiangnan.misty_bamboo_alley",
        "homePointId": "point.jiangnan.misty_bamboo_alley.connected_awning",
        "routine": { "day": "point.jiangnan.misty_bamboo_alley.connected_awning", "evening": "point.jiangnan.river_market.ledger_awning", "night": "point.jiangnan.misty_bamboo_alley.mo_workshop" },
        "fourEyeLean": { "inheritance": 1, "market": 0, "dailyLife": 2, "ritualFaith": 0 },
        "serviceIds": ["daily_commission.patch_umbrella"],
        "questIds": ["quest.jiangnan_rain_alley.side.resident_patch"],
        "assetRefIds": ["asset_group.jiangnan.npc_portraits"]
