{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangongdu.example/schemas/v1-content-catalog.schema.json",
  "title": "TianGongDu 1.0 Content Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "release",
    "contentTargets",
    "combatSystems",
    "weapons",
    "regions",
    "mainChapters",
    "questChains",
    "enemyFamilies",
    "f1VerticalSlice",
    "bosses",
    "npcs"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "release": { "const": "1.0" },
    "contentTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mainMinutes", "mainAndSideMinutes", "completionistMinutes", "regions", "subregions", "bosses", "coreNpcs", "combatSystems", "weaponFamilies", "mainChapters", "sideQuestChains", "enemyFamilies", "pointsOfInterest"],
      "properties": {
        "mainMinutes": { "type": "integer", "minimum": 900 },
        "mainAndSideMinutes": { "type": "integer", "minimum": 1200 },
        "completionistMinutes": { "type": "integer", "minimum": 1500 },
        "regions": { "type": "integer", "minimum": 3 },
        "subregions": { "type": "integer", "minimum": 15 },
        "bosses": { "type": "integer", "minimum": 10 },
        "coreNpcs": { "type": "integer", "minimum": 20 },
        "combatSystems": { "type": "integer", "minimum": 2 },
        "weaponFamilies": { "type": "integer", "minimum": 2 },
        "mainChapters": { "type": "integer", "minimum": 18 },
        "sideQuestChains": { "type": "integer", "minimum": 15 },
        "enemyFamilies": { "type": "integer", "minimum": 20 },
        "pointsOfInterest": { "type": "integer", "minimum": 100 }
      }
    },
    "combatSystems": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/combatSystem" }
    },
    "weapons": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/weapon" }
    },
    "regions": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/region" }
    },
    "mainChapters": {
      "type": "array",
      "minItems": 18,
      "items": { "$ref": "#/$defs/mainChapter" }
    },
    "questChains": {
      "type": "array",
      "minItems": 15,
      "items": { "$ref": "#/$defs/questChain" }
    },
    "enemyFamilies": {
      "type": "array",
      "minItems": 20,
      "items": { "$ref": "#/$defs/enemyFamily" }
    },
    "f1VerticalSlice": { "$ref": "#/$defs/f1VerticalSlice" },
    "bosses": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/boss" }
    },
    "npcs": {
      "type": "array",
      "minItems": 20,
      "items": { "$ref": "#/$defs/npc" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "combatSystem": {
      "type": "object",
      "required": ["id", "name", "purpose", "coreLoop", "progressionStages", "sharedResources"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "coreLoop": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "progressionStages": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "sharedResources": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/nonEmptyString" } }
      }
    },
    "weapon": {
      "type": "object",
      "required": ["id", "name", "combatIdentity", "stances", "craftDomains", "masteryCapstone", "futureHooks"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "combatIdentity": { "$ref": "#/$defs/nonEmptyString" },
        "stances": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "craftDomains": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "masteryCapstone": { "$ref": "#/$defs/nonEmptyString" },
        "futureHooks": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/nonEmptyString" } }
      }
    },
    "subregion": {
      "type": "object",
      "required": ["id", "name", "role", "signatureMechanic", "bossIds", "npcIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "signatureMechanic": { "$ref": "#/$defs/nonEmptyString" },
        "bossIds": { "type": "array", "items": { "$ref": "#/$defs/id" } },
        "npcIds": { "type": "array", "items": { "$ref": "#/$defs/id" } }
      }
    },
    "region": {
      "type": "object",
      "required": ["id", "name", "theme", "mainMinutes", "sideMinutes", "completionistMinutes", "mainChapters", "sideQuestChains", "pointsOfInterest", "subregions"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "theme": { "$ref": "#/$defs/nonEmptyString" },
        "mainMinutes": { "type": "integer", "minimum": 300 },
        "sideMinutes": { "type": "integer", "minimum": 90 },
        "completionistMinutes": { "type": "integer", "minimum": 480 },
        "mainChapters": { "type": "integer", "minimum": 6 },
        "sideQuestChains": { "type": "integer", "minimum": 5 },
        "pointsOfInterest": { "type": "integer", "minimum": 30 },
        "subregions": { "type": "array", "minItems": 5, "items": { "$ref": "#/$defs/subregion" } }
      }
    },
    "mainChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "regionId", "minutes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "regionId": { "$ref": "#/$defs/id" },
        "minutes": { "type": "integer", "minimum": 20, "maximum": 90 }
      }
    },
    "questChain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "regionId", "estimatedMinutes", "participantNpcIds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "regionId": { "$ref": "#/$defs/id" },
        "estimatedMinutes": { "type": "integer", "minimum": 15, "maximum": 60 },
        "participantNpcIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    },
    "enemyFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "regionId", "tacticalRole"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "regionId": { "$ref": "#/$defs/id" },
        "tacticalRole": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "f1VerticalSlice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "channel", "profileNamespace", "startFixtureId", "chapterId", "subregionIds", "npcIds", "enemyFamilyIds", "bossId", "playableTargetMinutes", "endToEndTestBudgetMinutes"],
      "properties": {
        "id": { "const": "f1_rainy_umbrella_trial" },
        "channel": { "const": "prototype_f1" },
        "profileNamespace": { "const": "prototype_f1" },
        "startFixtureId": { "const": "fixture_f1_rainy_umbrella_start" },
        "chapterId": { "$ref": "#/$defs/id" },
        "subregionIds": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "npcIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "enemyFamilyIds": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "bossId": { "$ref": "#/$defs/id" },
        "playableTargetMinutes": { "const": 60 },
        "endToEndTestBudgetMinutes": { "const": 70 }
      }
    },
    "boss": {
      "type": "object",
      "required": ["id", "name", "regionId", "rank", "phases", "coreMechanic", "resolutionSummary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "regionId": { "$ref": "#/$defs/id" },
        "rank": { "enum": ["elite", "chapter", "region"] },
        "phases": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "coreMechanic": { "$ref": "#/$defs/nonEmptyString" },
        "resolutionSummary": { "$ref": "#/$defs/nonEmptyString" }
      },
      "allOf": [
        { "if": { "properties": { "rank": { "const": "elite" } }, "required": ["rank"] }, "then": { "properties": { "phases": { "minItems": 2 } } } },
        { "if": { "properties": { "rank": { "const": "chapter" } }, "required": ["rank"] }, "then": { "properties": { "phases": { "minItems": 3 } } } },
        { "if": { "properties": { "rank": { "const": "region" } }, "required": ["rank"] }, "then": { "properties": { "phases": { "minItems": 4 } } } }
      ]
    },
    "npc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "regionId", "role", "relationshipArc", "interactionSystems", "questChainId", "questRole"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "regionId": { "$ref": "#/$defs/id" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "relationshipArc": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/nonEmptyString" } },
        "interactionSystems": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/id" } },
        "questChainId": { "$ref": "#/$defs/id" },
        "questRole": { "enum": ["owner", "co_protagonist", "support"] }
      }
    }
  }
}
