{
  "schemaVersion": 1,
  "id": "editor_template_set.jiangnan_content_v1",
  "displayNameKey": "editor_template_set.jiangnan_content_v1.name",
  "tags": ["editor", "jiangnan", "content_library", "schema", "tooling"],
  "designerNote": "江南章节化内容库的标准编辑器模板；编辑器只负责结构化读写，输出文本化内容数据。",
  "status": "draft",
  "sourceNote": "依据 doc/01 内容库与编辑器策略、doc/02 TOOLS-01、doc/13 六大区扩展目标。",
  "owner": "tools",
  "regionId": "region.jiangnan_rain_alley",
  "outputFormat": "json",
  "requiredBaseFields": ["schemaVersion", "id", "displayNameKey", "tags", "designerNote", "status", "owner", "sourceNote"],
  "templateIds": [
    "editor_template.jiangnan.character",
    "editor_template.jiangnan.large_area_point",
    "editor_template.jiangnan.building_interaction",
    "editor_template.jiangnan.craft_recipe",
    "editor_template.jiangnan.encounter",
    "editor_template.jiangnan.quest_flow",
    "editor_template.jiangnan.asset_ref"
  ],
  "templates": [
    {
      "id": "editor_template.jiangnan.character",
      "displayNameKey": "editor_template.jiangnan.character.name",
      "targetObjects": ["NpcDef", "DialogueProfileDef", "NpcScheduleDef"],
      "outputTargets": ["content/npcs/rain_alley_m1_npcs.json", "content/localization/zh-CN.json"],
      "requiredFields": ["id", "displayNameKey", "roles", "emotionalRole", "routine", "fourEyeLean", "homePointId"],
      "fieldGroups": [
        { "id": "identity", "fields": ["id", "displayNameKey", "tags", "roles", "emotionalRole"] },
        { "id": "placement", "fields": ["homeLargeAreaId", "homePointId", "homeBuildingId", "routine"] },
        { "id": "hooks", "fields": ["serviceIds", "questIds", "dialogueProfileIds", "assetRefIds"] }
      ],
      "validationRules": ["stable_id", "localization_key", "point_exists", "routine_has_day_evening_night", "asset_refs_resolve"],
      "demoPreview": { "surface": "editor-panel", "summaryFields": ["roles", "homePointId", "questIds"] }
    },
    {
      "id": "editor_template.jiangnan.large_area_point",
      "displayNameKey": "editor_template.jiangnan.large_area_point.name",
      "targetObjects": ["LargeAreaDef", "PointDef", "ConnectionDef"],
      "outputTargets": ["content/large_areas/jiangnan_large_areas.json", "content/assets/jiangnan_rain_alley_assets.json"],
      "requiredFields": ["id", "displayNameKey", "largeAreaId", "type", "coordinates", "contentRefs", "gates", "revisitStates"],
      "fieldGroups": [
        { "id": "map", "fields": ["largeAreaId", "coordinates", "themeColor", "mapAnchor"] },
        { "id": "content", "fields": ["contentRefs", "sourceSubregionId", "coverage"] },
        { "id": "revisit", "fields": ["gates", "revisitStates", "resourceLoop"] }
      ],
      "validationRules": ["large_area_exists", "point_count_between_6_and_12", "content_refs_resolve", "migration_from_07_complete", "connection_graph_reachable"],
      "demoPreview": { "surface": "large-map-panel", "summaryFields": ["primaryDimensions", "pointIds", "coverage"] }
    },
    {
      "id": "editor_template.jiangnan.building_interaction",
      "displayNameKey": "editor_template.jiangnan.building_interaction.name",
      "targetObjects": ["BuildingDef", "InteractionDef"],
      "outputTargets": ["content/buildings/jiangnan_rain_alley_buildings.json", "content/interactions/jiangnan_rain_alley_interactions.json"],
      "requiredFields": ["id", "displayNameKey", "regionId", "pointId", "type", "interactionIds", "effects"],
      "fieldGroups": [
        { "id": "placement", "fields": ["largeAreaId", "pointId", "buildingId"] },
        { "id": "trigger", "fields": ["type", "trigger", "conditions", "costs"] },
        { "id": "result", "fields": ["effects", "feedbackTargets", "fourEyeDeltas"] }
      ],
      "validationRules": ["point_exists", "npc_refs_resolve", "effect_refs_resolve", "choice_has_feedback_targets"],
      "demoPreview": { "surface": "interaction-list", "summaryFields": ["type", "conditions", "effects"] }
    },
    {
      "id": "editor_template.jiangnan.craft_recipe",
      "displayNameKey": "editor_template.jiangnan.craft_recipe.name",
      "targetObjects": ["CraftRecipeDef", "MaterialDef", "TraitDef"],
      "outputTargets": ["content/interactions/jiangnan_rain_alley_interactions.json", "content/assets/jiangnan_rain_alley_assets.json"],
      "requiredFields": ["id", "displayNameKey", "stationId", "requiredItems", "craftFields", "resultTraitId", "gameplayBonuses"],
      "fieldGroups": [
        { "id": "inputs", "fields": ["requiredItems", "stationId", "largeAreaId", "pointId"] },
        { "id": "process", "fields": ["craftFields", "qualityThresholds", "failureOutputIds"] },
        { "id": "outputs", "fields": ["resultTraitId", "assetVariantId", "gameplayBonuses", "npcReviewTargets"] }
      ],
      "validationRules": ["material_refs_resolve", "station_point_exists", "trait_or_variant_exists", "gameplay_bonus_bounds"],
      "demoPreview": { "surface": "craft-board", "summaryFields": ["requiredItems", "resultTraitId", "gameplayBonuses"] }
    },
    {
      "id": "editor_template.jiangnan.encounter",
      "displayNameKey": "editor_template.jiangnan.encounter.name",
      "targetObjects": ["EncounterDef", "EnemyDef", "BossPhaseDef"],
      "outputTargets": ["content/enemies/rain_alley_m1_enemies.json", "content/bosses/rain_alley_boss.json"],
      "requiredFields": ["id", "displayNameKey", "largeAreaId", "pointId", "enemyIds", "learningGoal", "rewards", "repeatability"],
      "fieldGroups": [
        { "id": "placement", "fields": ["largeAreaId", "pointId", "spawnRules"] },
        { "id": "mechanics", "fields": ["enemyIds", "trapIds", "learningGoal", "failureHandling"] },
        { "id": "rewards", "fields": ["drops", "unlockIds", "repeatability"] }
      ],
      "validationRules": ["enemy_refs_resolve", "point_exists", "reward_refs_resolve", "boss_phase_transition_valid"],
      "demoPreview": { "surface": "large-map-panel", "summaryFields": ["enemyIds", "learningGoal", "repeatability"] }
    },
    {
      "id": "editor_template.jiangnan.quest_flow",
      "displayNameKey": "editor_template.jiangnan.quest_flow.name",
      "targetObjects": ["QuestDef", "QuestStepDef", "ChoiceDef", "OutcomeDef"],
      "outputTargets": ["content/quests/jiangnan_rain_alley_quests.json", "content/world_events/rain_alley_choices.json"],
      "requiredFields": ["id", "displayNameKey", "type", "stepIds", "conditions", "rewards", "fourEyeDeltas"],
      "fieldGroups": [
        { "id": "flow", "fields": ["stepIds", "conditions", "nextStepRules", "completionCriteria"] },
        { "id": "choice", "fields": ["choiceIds", "fourEyeDeltas", "feedbackTargets"] },
        { "id": "records", "fields": ["tiangongRecordIds", "outcomeIds", "unlockIds"] }
      ],
      "validationRules": ["step_refs_resolve", "choice_feedback_count", "large_area_path_exists", "no_orphan_outcome"],
      "demoPreview": { "surface": "quest-track", "summaryFields": ["stepIds", "choiceIds", "completionCriteria"] }
    },
    {
      "id": "editor_template.jiangnan.asset_ref",
      "displayNameKey": "editor_template.jiangnan.asset_ref.name",
      "targetObjects": ["AssetPackDef", "AudioPackDef", "AssetRefDef"],
      "outputTargets": ["content/assets/jiangnan_rain_alley_assets.json", "content/audio/jiangnan_rain_alley_audio.json"],
      "requiredFields": ["id", "displayNameKey", "assetType", "referenceIds", "requiredCount", "status", "manifestKey"],
      "fieldGroups": [
        { "id": "identity", "fields": ["id", "assetType", "status", "owner"] },
        { "id": "references", "fields": ["referenceIds", "usageIds", "largeAreaIds", "pointIds"] },
        { "id": "shipping", "fields": ["manifestKey", "previewPath", "requiredStates", "compression"] }
      ],
      "validationRules": ["content_refs_resolve", "manifest_key_stable", "preview_optional", "shipping_format_allowed"],
      "demoPreview": { "surface": "production-board", "summaryFields": ["assetType", "referenceIds", "status"] }
    }
  ]
}
